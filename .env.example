FLASK_APP=run.py
FLASK_DEBUG=1
PORT=7017

# Database credentials (never hardcode these in compose / Dockerfile / code).
# In production POSTGRES_PASSWORD is injected from Infisical at deploy time.
POSTGRES_USER=juana_maria_web
POSTGRES_PASSWORD=
POSTGRES_DB=juana_maria_web

# Full connection string. In Docker the DB host is the UNIQUE container name
# (juana-maria-web-db), never the bare `db` alias — the bare alias collides
# across every project on the shared `proxy` network:
#   postgresql://juana_maria_web:${POSTGRES_PASSWORD}@juana-maria-web-db:5432/juana_maria_web
# For local dev against a local Postgres, use localhost:
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/DBNAME

# Umami analytics (public website id; not a secret).
UMAMI_WEBSITE_ID=b5d4b173-a160-49f5-8f0d-076e804d0007

# Public canonical origin. Set in production so alias hosts 301 here and SEO
# URLs (canonical/OG/sitemap/robots) are emitted on this origin regardless of
# which host served the request. Leave unset in dev to use the request's origin.
CANONICAL_URL=https://velaclasica.ar
# Hosts that 301-redirect to CANONICAL_URL (comma-separated; www + the internal
# nexttech subdomain). Leave unset in dev so no redirect happens.
REDIRECT_HOSTS=www.velaclasica.ar,juana-maria.nexttech.com.ar

# Admin panel (topic visibility). SECRET_KEY signs the session cookie and
# ADMIN_PASSWORD gates /admin. Both are secrets — in production they're injected
# from Infisical at deploy time, never committed. If ADMIN_PASSWORD is unset the
# admin panel can't be logged into.
SECRET_KEY=076e804d0007-b5d4b173-49f5-8f0d-vedsdf-1234567890
ADMIN_PASSWORD=admin
